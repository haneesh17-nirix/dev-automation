{
  "_comment": "Central config. Paths are relative to the target project root (set via TARGET_PROJECT_PATH in .env).",

  "project": {
    "name": "NIRIX BME Tracker",
    "siteUrl": "https://app.nirixtracking.in",
    "repoUrl": "https://github.com/haneesh17-nirix/nirix-tracking"
  },

  "versioning": {
    "strategy": "conventional-commits",
    "versionFile": "frontend/package.json",
    "tagPrefix": "v"
  },

  "docs": {
    "changelog": "docs/CHANGELOG.md",
    "architecture": "docs/ARCHITECTURE.md",
    "design": "docs/UI_DESIGN_PATTERNS.md",
    "apiDocs": "docs/API.md",
    "testLog": "docs/TEST-LOG.md",
    "changeLog": "docs/CHANGELOG.md"
  },

  "integration": {
    "baseUrl": "https://app.nirixtracking.in",
    "apiBaseUrl": "https://api.nirixtracking.in",
    "timeout": 15000,
    "apiEndpoints": [
      { "method": "GET",  "path": "/api/health",     "expect": 200, "label": "Main API health" },
      { "method": "GET",  "path": "/api/equipment",  "expect": 401, "label": "Equipment (auth guard)" },
      { "method": "GET",  "path": "/api/tenants",    "expect": 401, "label": "Tenants (auth guard)" }
    ],
    "pages": [
      { "path": "/",           "label": "Landing" },
      { "path": "/login",      "label": "Login" },
      { "path": "/dashboard",  "label": "Dashboard" },
      { "path": "/requests",   "label": "Requests" },
      { "path": "/equipment",  "label": "Equipment" }
    ]
  },

  "testing": {
    "testDir": "tests",
    "generatedDir": "tests/generated",
    "unitPattern": "**/*.test.ts",
    "integrationPattern": "tests/integration/**/*.ts"
  },

  "logging": {
    "logDir": "logs",
    "deployLog": "logs/deployments.log",
    "changeLog": "logs/changes.log",
    "testLog": "logs/test-runs.log",
    "errorLog": "logs/errors.log"
  },

  "ollama": {
    "host": "http://localhost:11434",
    "model": "llama3.2",
    "fallback": "mistral"
  }
}
